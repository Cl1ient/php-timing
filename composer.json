{
    "name": "pokedrop/php-timings",
    "description": "Système de timings pour PHP inspiré de PocketMine-MP (mesure de performances hiérarchique + rapport).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "pokedrop",
            "email": "pokedrop.pro@gmail.com"
        }
    ],
    "require": {
